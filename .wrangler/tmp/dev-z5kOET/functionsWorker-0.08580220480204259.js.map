  {
    "topic": "模式编码",
    "englishName": "Pattern Coding",
    "theoryRules": {
      "objective": "将第一轮产生的零散标签聚类",
      "criteria": [
        {
          "name": "相似性",
          "englishName": "Similarity",
          "description": "逻辑上属于同一范畴的动作"
