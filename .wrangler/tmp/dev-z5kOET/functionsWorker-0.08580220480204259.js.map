    "知识点": {
      "过程编码": {
        "定义": "使用动名词概括数据，捕捉动作和演变",
        "方法": {
          "动名词形式": "使用'-ing'结尾的词或中文的'正在...'、'通过...来...'",
          "重点": "捕捉'动作'和'演变'"
        }
      },
      "本土编码": {
        "定义": "提取受访者口中的原生词汇，保留研究对象的原声",
        "方法": {
          "优先提取": "受访者口中的原生词汇（In Vivo）",
          "目的": "增强学术溯源的真实感"
        }
      },
      "应用逻辑": {
        "避免": "使用抽象的形容词（如'伤心的'）",
        "应使用": "具象的动作描述（如'通过沉默表达抗议'）"
      }
    }
