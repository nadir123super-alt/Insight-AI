        {
          "name": "差异性",
          "englishName": "Difference",
          "description": "在同一主题下表现出的对立状态"
        },
        {
          "name": "频率",
          "englishName": "Frequency",
          "description": "高频出现的现象往往构成了研究的核心维度"
        }
      ]
    },
    "applicationLogic": {
      "example": {
        "observation": "当AI发现'寻找搭子'和'加入社群'同时出现时",
